# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Force LF for all common text files
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# Shell scripts must use LF
*.sh text eol=lf
mvnw text eol=lf
gradlew text eol=lf

# Docker files
Dockerfile* text eol=lf
*.dockerfile text eol=lf
docker-compose*.yml text eol=lf

# Git config files
.gitattributes text eol=lf
.gitignore text eol=lf

# Keep Windows batch files with CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

