# JHipster Development Container
# Based on Eclipse Temurin JDK 21 with JHipster 8.11.0
# Includes: Java 21, Node.js 22, JHipster CLI
# Security: Runs as non-root user (jhipster)

FROM eclipse-temurin:21-jdk-jammy AS base

# Use bash with pipefail for safer pipe handling
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# Install system dependencies as root
# hadolint ignore=DL3008
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    bash \
    bash-completion \
    curl \
    ca-certificates \
    openssh-client \
    vim \
    wget \
    jq \
    xz-utils \
    # Dependencies for JHipster JDL extension (diagram rendering)
    graphviz \
    fonts-dejavu \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user with proper permissions
ARG USER_UID=1000
ARG USER_GID=1000
RUN groupadd -g ${USER_GID} jhipster && \
    useradd -l -m -u ${USER_UID} -g jhipster -s /bin/bash jhipster && \
    # Create workspace directory
    mkdir -p /home/jhipster/app && \
    # Create Maven and npm cache directories with correct ownership
    mkdir -p /home/jhipster/.m2/repository \
             /home/jhipster/.m2/wrapper \
             /home/jhipster/.npm \
             /home/jhipster/.cache \
             /home/jhipster/.config && \
    # Set ownership for all user directories
    chown -R jhipster:jhipster /home/jhipster && \
    # Lock root account to prevent privilege escalation
    passwd -l root && \
    # Remove sudo capabilities if present
    rm -f /etc/sudoers.d/* 2>/dev/null || true

# Node.js 22 LTS (required for JHipster 8.11.0)
ARG NODE_VERSION=22.15.0
ARG NVM_VERSION=0.40.1

# Set environment variables
ENV NVM_DIR=/home/jhipster/.nvm
ENV NODE_VERSION=${NODE_VERSION}
ENV JAVA_HOME=/opt/java/openjdk
ENV PATH=${JAVA_HOME}/bin:${PATH}

# Switch to non-root user
USER jhipster

# Install NVM and Node.js
# hadolint ignore=SC1091
RUN curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v${NVM_VERSION}/install.sh | bash && \
    . "${NVM_DIR}/nvm.sh" && \
    nvm install ${NODE_VERSION} && \
    nvm use ${NODE_VERSION} && \
    nvm alias default ${NODE_VERSION}

# Set Node.js in PATH
ENV NODE_PATH=${NVM_DIR}/versions/node/v${NODE_VERSION}/lib/node_modules
ENV PATH=${NVM_DIR}/versions/node/v${NODE_VERSION}/bin:${PATH}

# Install JHipster CLI globally
# Using yo@4.3.1 for compatibility with generator-jhipster
# hadolint ignore=DL3059,SC1091
RUN . "${NVM_DIR}/nvm.sh" && \
    npm install -g generator-jhipster@8.11.0 yo@4.3.1

# Configure bash environment
# hadolint ignore=DL3059,SC2016
RUN { \
    echo ''; \
    echo '# Java environment'; \
    echo 'export JAVA_HOME=/opt/java/openjdk'; \
    echo 'export PATH="$JAVA_HOME/bin:$PATH"'; \
    echo ''; \
    echo '# Load NVM'; \
    echo 'export NVM_DIR="$HOME/.nvm"'; \
    echo '[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"'; \
    echo '[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"'; \
    echo ''; \
    echo '# Aliases'; \
    echo 'alias jh="jhipster"'; \
    echo 'alias ll="ls -la"'; \
    } >> /home/jhipster/.bashrc

# Install Claude Code CLI
# hadolint ignore=DL3059
RUN curl -fsSL https://claude.ai/install.sh | bash

# Set working directory
WORKDIR /home/jhipster/app

# Verify installations
RUN java -version && \
    node --version && \
    npm --version && \
    jhipster --version

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD java -version && node --version && jhipster --version || exit 1

# Ensure non-root user
USER jhipster

# Default command
CMD ["tail", "-f", "/dev/null"]

